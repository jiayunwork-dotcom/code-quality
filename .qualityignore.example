# 忽略规则文件，语法类似.gitignore

# 忽略所有测试文件
*_test.go
**/test/**
**/tests/**

# 忽略第三方代码
**/third_party/**
**/vendor/**
**/node_modules/**

# 忽略生成的代码
**/generated/**
*.generated.*

# 忽略特定规则
# 格式: ignore:<rule-id> <pattern>
ignore:cyclomatic-complexity **/migrations/*.py
ignore:function-length **/database/*.sql

# 否定模式 (不忽略)
!important/**
